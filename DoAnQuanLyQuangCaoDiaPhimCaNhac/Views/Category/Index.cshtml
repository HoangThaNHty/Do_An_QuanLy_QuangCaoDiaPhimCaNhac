@model List<DoAnQuanLyQuangCaoDiaPhimCaNhac.Models.LoaiDia>

<h2 class="text-white">🎵 Quản Lý Thể Loại Đĩa</h2>

<a href="~/Category/Create" class="btn btn-primary mb-3">➕ Thêm Thể Loại</a>

@if (TempData["Success"] != null)
{
    <div class="alert alert-success">@TempData["Success"]</div>
}
@if (TempData["Error"] != null)
{
    <div class="alert alert-danger">@TempData["Error"]</div>
}

<table class="table table-dark table-bordered">
    <thead>
        <tr>
            <th>Mã Loại</th>
            <th>Tên Loại</th>
            <th style="width: 150px">Thao Tác</th>
        </tr>
    </thead>
    <tbody>
        @foreach (var item in Model)
        {
            <tr>
                <td>@item.MaLoaiDia</td>
                <td>@item.TenLoaiDia</td>
                <td>
                    <a href="~/Category/Edit/@item.MaLoaiDia" class="btn btn-warning btn-sm">Sửa</a>
                    <a href="~/Category/Delete/@item.MaLoaiDia" class="btn btn-danger btn-sm">Xóa</a>
                </td>
            </tr>
        }
    </tbody>
</table>
