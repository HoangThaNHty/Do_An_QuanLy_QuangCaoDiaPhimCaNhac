@model IEnumerable<DoAnQuanLyQuangCaoDiaPhimCaNhac.Models.DiaPhimCaNhac>
@{
    ViewBag.Title = "Kết quả lọc sản phẩm";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<style>
    /* ====== CARD SẢN PHẨM ====== */
    .product-card {
        background-color: #1a1a1a;
        border: 1px solid #333;
        border-radius: 10px;
        overflow: hidden;
        position: relative;
        transition: all 0.35s ease;
        height: 100%;
    }

        .product-card:hover {
            border-color: #ffc107;
            transform: translateY(-6px);
            box-shadow: 0 6px 20px rgba(255, 193, 7, 0.15);
        }

        .product-card img {
            width: 100%;
            height: 250px;
            object-fit: cover;
            transition: transform 0.4s ease, opacity 0.4s ease;
        }

        .product-card:hover img {
            transform: scale(1.05);
            opacity: 0.9;
        }

        .product-card .card-body {
            padding: 15px;
        }

        .product-card h5 {
            color: #fff;
            font-size: 16px;
            margin-bottom: 8px;
            min-height: 40px;
            display: -webkit-box;
            -webkit-line-clamp: 2;
            -webkit-box-orient: vertical;
            overflow: hidden;
        }

        .product-card .price {
            color: #ffc107;
            font-weight: bold;
            font-size: 18px;
            margin-top: 8px;
            margin-bottom: 0;
        }

        /* ====== RATING ====== */
        .product-card .rating {
            display: flex;
            align-items: center;
            gap: 2px;
            font-size: 14px;
            margin-bottom: 8px;
        }

            .product-card .rating i {
                font-size: 16px;
            }

            .product-card .rating small {
                color: #aaa;
                margin-left: 5px;
            }

    /* ====== BADGE "NỔI BẬT" ====== */
    .badge-featured {
        position: absolute;
        top: 10px;
        left: 10px;
        background: linear-gradient(90deg, #ffc107, #ff6600);
        color: #000;
        font-weight: 600;
        font-size: 12px;
        padding: 4px 10px;
        border-radius: 20px;
        display: flex;
        align-items: center;
        gap: 4px;
        box-shadow: 0 2px 6px rgba(0,0,0,0.4);
    }

    /* ====== TIÊU ĐỀ PHẦN ====== */
    h2.section-title {
        color: #fff;
        font-weight: 600;
        display: flex;
        align-items: center;
        gap: 8px;
        margin-bottom: 20px;
    }

    hr.border-light {
        border-color: #333 !important;
        margin: 40px 0;
    }
</style>

<div class="container-fluid">
    <!-- Header với thông tin lọc -->
    <div class="row mb-3">
        <div class="col-12">
            <h2 class="text-white mb-3">
                @Html.Raw(ViewBag.Icon) Kết quả lọc sản phẩm
            </h2>

            <!-- Hiển thị các bộ lọc đang áp dụng -->
            @if (ViewBag.Loai != null || (ViewBag.SelectedPrices != null && ((List<string>)ViewBag.SelectedPrices).Any()))
            {
                <div class="mb-3">
                    <span class="text-secondary">Đang lọc theo: </span>

                    @if (ViewBag.Loai != null)
                    {
                        <span class="filter-badge">
                            <i class="bi bi-tag"></i> @ViewBag.Loai
                            <span class="remove" onclick="removeFilter('loai')">×</span>
                        </span>
                    }

                    @if (ViewBag.SelectedPrices != null)
                    {
                        foreach (var price in (List<string>)ViewBag.SelectedPrices)
                        {
                            string priceLabel = "";
                            switch (price)
                            {
                                case "under100": priceLabel = "Dưới 100k"; break;
                                case "100-300": priceLabel = "100k - 300k"; break;
                                case "300-500": priceLabel = "300k - 500k"; break;
                                case "over500": priceLabel = "Trên 500k"; break;
                            }
                            <span class="filter-badge">
                                <i class="bi bi-currency-dollar"></i> @priceLabel
                                <span class="remove" onclick="removeFilter('price', '@price')">×</span>
                            </span>
                        }
                    }
                </div>
            }
        </div>
    </div>

    <!-- Thanh sắp xếp và thống kê -->
    <div class="row">
        <div class="col-12">
            <div class="sort-controls d-flex justify-content-between align-items-center">
                <div>
                    <span class="text-white">
                        Tìm thấy <strong class="text-warning">@ViewBag.Count</strong> sản phẩm
                    </span>
                </div>

                <div class="d-flex align-items-center gap-2">
                    <label class="text-white me-2">Sắp xếp:</label>
                    <select id="sortSelect" class="form-select form-select-sm" style="width: auto; background-color: #333; color: white; border-color: #555;">
                        <option value="newest">Mới nhất</option>
                        <option value="price-asc">Giá tăng dần</option>
                        <option value="price-desc">Giá giảm dần</option>
                        <option value="name">Tên A-Z</option>
                        <option value="popular">Phổ biến</option>
                    </select>
                </div>
            </div>
        </div>
    </div>

    <!-- Danh sách sản phẩm -->
    @if (!Model.Any())
    {
        <div class="row mt-5">
            <div class="col-12 text-center">
                <div style="background-color: #1a1a1a; padding: 50px; border-radius: 8px; border: 1px solid #333;">
                    <i class="bi bi-inbox" style="font-size: 64px; color: #666;"></i>
                    <h3 class="text-warning mt-3">Không tìm thấy sản phẩm phù hợp</h3>
                    <p class="text-secondary">Vui lòng thử thay đổi bộ lọc hoặc tìm kiếm khác</p>
                    <a href="@Url.Action("Index", "Home")" class="btn btn-outline-light mt-3">
                        <i class="bi bi-arrow-left"></i> Quay lại trang chủ
                    </a>
                </div>
            </div>
        </div>
    }
    else
    {
        <div class="row mt-4" id="productList">
            @foreach (var item in Model)
            {
                <div class="col-md-3 mb-4 product-item"
                     data-price="@item.GiaBan"
                     data-name="@item.TenDia"
                     data-date="@(item.NgayCapNhat?.ToString("yyyyMMdd") ?? DateTime.Now.ToString("yyyyMMdd"))"
                     data-views="@(item.SoLuotXem ?? 0)">
                    <div class="product-card">
                        <a href="@Url.Action("ChiTiet", "Home", new { maDia = item.MaDia })">
                            <img src="~/Content/Images/@item.AnhBia" alt="@item.TenDia"
                                 onerror="this.src='/Content/Images/default.jpg'" />
                        </a>
                        <div class="card-body">
                            <h5 title="@item.TenDia">@item.TenDia</h5>

                            @if (item.DanhGia != null && item.DanhGia > 0)
                            {
                                <div class="rating">
                                    @for (int i = 1; i <= 5; i++)
                                    {
                                        if (i <= item.DanhGia)
                                        {
                                            <i class="bi bi-star-fill text-warning"></i>
                                        }
                                        else
                                        {
                                            <i class="bi bi-star text-secondary"></i>
                                        }
                                    }
                                    (@item.DanhGia ⭐)
                                </div>
                            }

                            <p class="price">@item.GiaBan.ToString("N0") VNĐ</p>
                        </div>
                    </div>
                </div>
            }
        </div>
    }
</div>

<script>
// Sắp xếp sản phẩm
document.getElementById('sortSelect')?.addEventListener('change', function() {
    const sortValue = this.value;
    const productList = document.getElementById('productList');
    const products = Array.from(document.querySelectorAll('.product-item'));

    products.sort((a, b) => {
        switch(sortValue) {
            case 'price-asc':
                return parseFloat(a.dataset.price) - parseFloat(b.dataset.price);
            case 'price-desc':
                return parseFloat(b.dataset.price) - parseFloat(a.dataset.price);
            case 'name':
                return a.dataset.name.localeCompare(b.dataset.name);
            case 'popular':
                return parseInt(b.dataset.views) - parseInt(a.dataset.views);
            case 'newest':
            default:
                return b.dataset.date.localeCompare(a.dataset.date);
        }
    });

    products.forEach(product => productList.appendChild(product));
});

// Xóa bộ lọc
function removeFilter(type, value) {
    const urlParams = new URLSearchParams(window.location.search);

    if (type === 'loai') {
        urlParams.delete('loai');
    } else if (type === 'price') {
        const prices = urlParams.getAll('price');
        urlParams.delete('price');
        prices.filter(p => p !== value).forEach(p => urlParams.append('price', p));
    }

    const newUrl = urlParams.toString() ?
        window.location.pathname + '?' + urlParams.toString() :
        '@Url.Action("Index", "Home")';

    window.location.href = newUrl;
}
</script>