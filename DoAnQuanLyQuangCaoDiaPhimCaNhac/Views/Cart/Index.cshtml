@model List<DoAnQuanLyQuangCaoDiaPhimCaNhac.Models.GioHang>

@{
    ViewBag.Title = "Giỏ Hàng";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<!DOCTYPE html>
<html lang="vi">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>Giỏ Hàng - MusicWeb</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet" />
    <style>
        body {
            background-color: #000;
            color: white;
        }
        .card {
            background-color: #111;
            border: 1px solid white;
            margin-bottom: 20px;
        }
        .card-header {
            background-color: #222;
            border-bottom: 1px solid white;
            color: white;
        }
        .table {
            color: white;
        }
        .table th {
            background-color: #222;
            border-color: #444;
            color: white;
        }
        .table td {
            background-color: #111;
            border-color: #444;
        }
        .product-image {
            width: 80px;
            height: 80px;
            object-fit: cover;
            border-radius: 5px;
        }
        .quantity-input {
            width: 80px;
            background-color: #222;
            border: 1px solid #444;
            color: white;
            text-align: center;
        }
        .btn-outline-primary {
            border-color: #007bff;
            color: #007bff;
        }
        .btn-outline-primary:hover {
            background-color: #007bff;
            border-color: #007bff;
            color: white;
        }
        .btn-outline-danger {
            border-color: #dc3545;
            color: #dc3545;
        }
        .btn-outline-danger:hover {
            background-color: #dc3545;
            border-color: #dc3545;
            color: white;
        }
        .total-amount {
            font-size: 1.5rem;
            font-weight: bold;
            color: #007bff;
        }
        .modal-content {
            background-color: #111;
            border: 1px solid white;
        }
        .modal-header {
            background-color: #222;
            border-bottom: 1px solid white;
            color: white;
        }
        .form-control {
            background-color: #222;
            border: 1px solid #444;
            color: white;
        }
        .form-control:focus {
            background-color: #222;
            border-color: #007bff;
            color: white;
        }

        body {
            background-color: #000;
            color: white;
        }

        /* Card và header giữ nguyên */
        .card {
            background-color: #111;
            border: 1px solid white;
            margin-bottom: 20px;
        }

        .card-header {
            background-color: #222;
            border-bottom: 1px solid white;
            color: #fff;
        }

        /* Bảng giỏ hàng */
        .table {
            color: #fff;
        }

            .table th {
                background-color: #222;
                border-color: #444;
                color: #fff !important; /* ✅ trắng rõ hơn */
            }

            .table td {
                background-color: #111;
                border-color: #444;
                color: #fff !important; /* ✅ chữ trắng */
            }

        /* Tên sản phẩm và mã */
        h6 {
            color: #fff !important; /* ✅ tên đĩa nổi bật */
            margin-bottom: 4px;
        }

        small.text-muted {
            color: #ccc !important; /* ✅ mã sản phẩm sáng hơn, không chìm */
        }

        /* Nút và input */
        .quantity-input {
            width: 80px;
            background-color: #222;
            border: 1px solid #666;
            color: #fff;
            text-align: center;
        }

        .btn-outline-primary {
            border-color: #007bff;
            color: #007bff;
        }

            .btn-outline-primary:hover {
                background-color: #007bff;
                border-color: #007bff;
                color: #fff;
            }

        .btn-outline-danger {
            border-color: #dc3545;
            color: #dc3545;
        }

            .btn-outline-danger:hover {
                background-color: #dc3545;
                border-color: #dc3545;
                color: #fff;
            }

        /* Tổng tiền nổi bật hơn */
        .total-amount {
            font-size: 1.5rem;
            font-weight: bold;
            color: #0d6efd; /* xanh sáng */
        }

        /* ✅ Căn giữa nội dung trong cột Giá, Số lượng và Thao tác */
        .table td:nth-child(2),
        .table td:nth-child(3),
        .table td:nth-child(4),
        .table th:nth-child(2),
        .table th:nth-child(3),
        .table th:nth-child(4) {
            text-align: center;
            vertical-align: middle;
        }

        /* ✅ Canh giữa input và nút trong ô */
        .table td input.quantity-input {
            margin: 0 auto;
            display: block;
        }

        .table td button {
            display: block;
            margin: 0 auto;
        }

        /* ✅ Căn giữa toàn bộ nội dung bảng giỏ hàng */
        .table th,
        .table td {
            text-align: center;
            vertical-align: middle !important;
        }

            /* ✅ Giữ ảnh và tên đĩa hiển thị đẹp */
            .table td:first-child {
                text-align: left; /* vẫn căn trái ảnh + tên cho tự nhiên */
                vertical-align: middle;
            }

                /* ✅ Ảnh căn giữa theo chiều dọc, cách đều tên */
                .table td:first-child .d-flex {
                    align-items: center;
                }

        /* ✅ Input và nút Xóa ở giữa ô */
        .quantity-input {
            display: block;
            margin: 0 auto;
        }

        .table td button {
            display: block;
            margin: 0 auto;
        }

        /* ✅ Làm ảnh và tên đĩa gọn gàng hơn */
        .product-image {
            width: 80px;
            height: 80px;
            object-fit: cover;
            border-radius: 6px;
            margin-right: 10px;
        }

        /* ✅ Tên đĩa nổi bật, canh đều trong ô */
        .table td:first-child h6 {
            color: #fff;
            font-weight: 600;
            margin-bottom: 4px;
        }

        /* ✅ Style cho ô nhập số lượng giống với <h6> */
        .quantity-input {
            width: 80px;
            height: 38px; /* cho bằng chiều cao chữ <h6> */
            background-color: #111; /* đồng màu với nền bảng */
            border: 1px solid #555;
            color: #fff; /* trắng như h6 */
            text-align: center;
            font-size: 1rem; /* cùng cỡ chữ h6 */
            font-weight: 600; /* đậm tương tự h6 */
            border-radius: 6px;
            transition: all 0.2s ease-in-out;
        }

            .quantity-input:focus {
                border-color: #0d6efd;
                outline: none;
                background-color: #222;
            }

    </style>
</head>
<body>
    <div class="container-fluid mt-4">
        <h2 class="mb-4">GIỎ HÀNG CỦA BẠN</h2>

        @if (TempData["ErrorMessage"] != null)
        {
            <div class="alert alert-danger">@TempData["ErrorMessage"]</div>
        }

        @if (TempData["SuccessMessage"] != null)
        {
            <div class="alert alert-success">@TempData["SuccessMessage"]</div>
        }

        @if (Model.Any())
        {
            <div class="row">
                <div class="col-md-8">
                    <div class="card">
                        <div class="card-header">
                            <h5>Sản Phẩm Trong Giỏ (@Model.Count sản phẩm)</h5>
                        </div>
                        <div class="card-body">
                            <div class="table-responsive">
                                <table class="table">
                                    <thead>
                                        <tr>
                                            <th>Sản Phẩm</th>
                                            <th>Giá</th>
                                            <th>Số Lượng</th>
                                            @*<th>Thành Tiền</th>*@
                                            <th>Thao Tác</th>
                                        </tr>
                                    </thead>
                                    <tbody>
                                        @foreach (var item in Model)
                                        {
                                            <tr id="row-@item.MaDia">
                                                <td>
                                                    <div class="d-flex align-items-center">
                                                        @*@if (!string.IsNullOrEmpty(item.DiaPhimCaNhac.AnhBia))
                                                        {

                                                            <img src="~/Content/Images/@item.DiaPhimCaNhac.AnhBia" alt="@item.DiaPhimCaNhac.TenDia" class="product-image me-3" />
                                                        }
                                                        else
                                                        {
                                                            <div class="product-image bg-secondary me-3"></div>
                                                        }*@
                                                        @if (!string.IsNullOrEmpty(item.DiaPhimCaNhac.AnhBia))
                                                        {
                                                            <a href="@Url.Action("ChiTiet", "Home", new { maDia = item.DiaPhimCaNhac.MaDia })">
                                                                <img src="~/Content/Images/@item.DiaPhimCaNhac.AnhBia"
                                                                     alt="@item.DiaPhimCaNhac.TenDia"
                                                                     class="product-image me-3"
                                                                     style="cursor:pointer;" />
                                                            </a>
                                                        }
                                                        else
                                                        {
                                                            <a href="@Url.Action("ChiTiet", "Home", new { maDia = item.DiaPhimCaNhac.MaDia })">
                                                                <div class="product-image bg-secondary me-3" style="cursor:pointer;"></div>
                                                            </a>
                                                        }

                                                        <div>
                                                            <h6>@item.DiaPhimCaNhac.TenDia</h6>
                                                            @*<small class="text-muted">@item.DiaPhimCaNhac.MaDia</small>*@
                                                        </div>
                                                    </div>
                                                </td>
                                                <td @*style="color: #fff !important; /* ✅ tên đĩa nổi bật */ margin-bottom: 4px;"*@>
                                                    <h6>
                                                        @string.Format("{0:N0} VNĐ", item.DiaPhimCaNhac.GiaBan)
                                                    </h6>
                                                </td>
                                                <td>
                                                    <input type="number" class="quantity-input" value="@item.SoLuong" 
                                                           min="1" max="@item.DiaPhimCaNhac.SoLuongTon" 
                                                           oninput="validateQuantity(this, @item.DiaPhimCaNhac.SoLuongTon)" 
                                                           onblur="validateQuantity(this, @item.DiaPhimCaNhac.SoLuongTon)"
                                                           onchange="updateQuantity(@item.MaDia, this.value)" />
                                                    @*<small class="d-block text-muted">Còn: @item.DiaPhimCaNhac.SoLuongTon</small>*@
                                                </td>
                                                @*<td id="subtotal-@item.MaDia">@string.Format("{0:N0} VNĐ", item.SoLuong * item.DiaPhimCaNhac.GiaBan)</td>*@
                                                <td>
                                                    <button type="button" class="btn btn-outline-danger btn-sm" onclick="removeFromCart(@item.MaDia)">
                                                        🗑️ Xóa
                                                    </button>
                                                </td>
                                            </tr>
                                        }
                                    </tbody>
                                </table>
                            </div>
                        </div>
                    </div>
                </div>

                <div class="col-md-4">
                    <div class="card">
                        <div class="card-header">
                            <h5>Tổng Thành Tiền</h5>
                        </div>
                        <div class="card-body">
                            <div class="d-flex justify-content-between mb-3">
                                <span>Tạm Tính:</span>
                                <span id="subtotal">@string.Format("{0:N0} VNĐ", ViewBag.TotalAmount)</span>
                            </div>
                            <div class="d-flex justify-content-between mb-3">
                                <span>Phí Ship:</span>
                                <span>Miễn Phí</span>
                            </div>
                            <hr style="border-color: #444;">
                            <div class="d-flex justify-content-between mb-3 total-amount">
                                <span>Tổng Cộng:</span>
                                <span id="total">@string.Format("{0:N0} VNĐ", ViewBag.TotalAmount)</span>
                            </div>
                            
                            <button type="button" class="btn btn-primary w-100 mb-2" onclick="showCheckoutModal()">
                                💳 Thanh Toán
                            </button>
                            
                            <a href="@Url.Action("Index", "Home")" class="btn btn-outline-primary w-100">
                                ← Tiếp Tục Mua Sắm
                            </a>
                        </div>
                    </div>
                </div>
            </div>
        }
        else
        {
            <div class="card">
                <div class="card-body text-center py-5">
                    <h4 style="color:white">Giỏ hàng trống</h4>
                    <p @*class="text-muted"*@ style="color:white">Bạn chưa có sản phẩm nào trong giỏ hàng.</p>
                    <a href="@Url.Action("Index", "Home")" class="btn btn-primary">Bắt Đầu Mua Sắm</a>
                </div>
            </div>
        }
    </div>

    <!-- Checkout Modal -->
    <div class="modal fade" id="checkoutModal" tabindex="-1">
        <div class="modal-dialog modal-lg">
            <div class="modal-content">
                <div class="modal-header">
                    <h5 class="modal-title">Thông Tin Thanh Toán</h5>
                    <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
                </div>
                <div class="modal-body">
                    @using (Html.BeginForm("Checkout", "Cart", FormMethod.Post, new { id = "checkoutForm" }))
                    {
                        <div class="row">
                            <div class="col-md-12 mb-3">
                                <label for="diaChiGiao" class="form-label">Địa Chỉ Giao Hàng *</label>
                                <textarea class="form-control" id="diaChiGiao" name="diaChiGiao" rows="3" required 
                                          placeholder="Nhập địa chỉ giao hàng chi tiết..."></textarea>
                            </div>
                            
                            <div class="col-md-6 mb-3">
                                <label for="phuongThucThanhToan" class="form-label">Phương Thức Thanh Toán</label>
                                <select class="form-control" id="phuongThucThanhToan" name="phuongThucThanhToan">
                                    <option value="Tiền mặt">Tiền mặt</option>
                                    <option value="Chuyển khoản">Chuyển khoản</option>
                                    <option value="Thẻ tín dụng">Thẻ tín dụng</option>
                                </select>
                            </div>
                            
                            <div class="col-md-12 mb-3">
                                <label for="ghiChu" class="form-label">Ghi Chú</label>
                                <textarea class="form-control" id="ghiChu" name="ghiChu" rows="2" 
                                          placeholder="Ghi chú thêm (không bắt buộc)..."></textarea>
                            </div>
                        </div>
                    }
                </div>
                <div class="modal-footer">
                    <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Hủy</button>
                    <button type="button" class="btn btn-primary" onclick="submitCheckout()">Xác Nhận Đặt Hàng</button>
                </div>
            </div>
        </div>
    </div>

    @*<script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>*@
    <script>
        // ✅ Hàm kiểm tra số lượng hợp lệ
        function validateQuantity(input, maxValue) {
            let value = parseInt(input.value);

            // Nếu nhập rỗng hoặc nhỏ hơn 1 → về 1
            if (isNaN(value) || value < 1) {
                input.value = 1;
            }

            // Nếu nhập lớn hơn số lượng tồn → về maxValue
            if (value > maxValue) {
                input.value = maxValue;
            }
        }
        function updateQuantity(maDia, soLuong) {
            $.ajax({
                url: '@Url.Action("UpdateQuantity", "Cart")',
                type: 'POST',
                data: {
                    maDia: maDia,
                    soLuong: parseInt(soLuong)
                },
                success: function(response) {
                    if (response.success) {
                        // Cập nhật UI
                        $('#cartCount').text(response.cartCount);
                        if (response.totalAmount !== undefined) {
                            $('#total').text(formatCurrency(response.totalAmount));
                        }
                    } else {
                        alert(response.message);
                        location.reload(); // Reload if error
                    }
                },
                error: function() {
                    alert('Có lỗi xảy ra!');
                }
            });
        }

        function removeFromCart(maDia) {
            if (confirm('Bạn có chắc chắn muốn xóa sản phẩm này khỏi giỏ hàng?')) {
                $.ajax({
                    url: '@Url.Action("RemoveFromCart", "Cart")',
                    type: 'POST',
                    data: { maDia: maDia },
                    success: function(response) {
                        if (response.success) {
                            $('#row-' + maDia).remove();
                            $('#cartCount').text(response.cartCount);
                            $('#total').text(formatCurrency(response.totalAmount));
                            
                            // Reload trang nếu giỏ hàng trống
                            if (response.cartCount === 0) {
                                location.reload();
                            }
                        } else {
                            alert(response.message);
                        }
                    },
                    error: function() {
                        alert('Có lỗi xảy ra!');
                    }
                });
            }
        }

        function showCheckoutModal() {
            new bootstrap.Modal(document.getElementById('checkoutModal')).show();
        }

        function submitCheckout() {
            var diaChi = document.getElementById('diaChiGiao').value.trim();
            if (!diaChi) {
                alert('Vui lòng nhập địa chỉ giao hàng!');
                return;
            }
            
            document.getElementById('checkoutForm').submit();
        }

        function formatCurrency(amount) {
            return new Intl.NumberFormat('vi-VN', {
                style: 'currency',
                currency: 'VND'
            }).format(amount).replace('₫', 'VNĐ');
        }
    </script>
</body>
</html>