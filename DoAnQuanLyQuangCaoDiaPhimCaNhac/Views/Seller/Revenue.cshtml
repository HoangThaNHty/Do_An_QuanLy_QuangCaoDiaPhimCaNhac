@{
    ViewBag.Title = "Thống kê doanh thu";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/animate.css/4.1.1/animate.min.css" />
<script src="https://cdn.jsdelivr.net/npm/chart.js"></script>

<div class="container mt-4">

    <h2 class="mb-4 text-center animate__animated animate__fadeInDown">
        📊 Thống Kê Doanh Thu Người Bán
    </h2>

    <!-- Tổng doanh thu -->
    <div class="card shadow mb-4 animate__animated animate__zoomIn">
        <div class="card-body text-center">
            <h4 style="font-weight:600">Tổng doanh thu</h4>
            <h1 style="color:#28a745; font-weight:700;">
                @String.Format("{0:N0}", ViewBag.TotalRevenue) VNĐ
            </h1>
        </div>
    </div>

    <!-- Biểu đồ doanh thu theo tháng -->
    <div class="row mb-4">
        <div class="col-md-8">
            <div class="card shadow animate__animated animate__fadeInLeft">
                <div class="card-header bg-primary text-white">
                    <strong>📅 Doanh thu 6 tháng gần đây</strong>
                </div>
                <div class="card-body">
                    <canvas id="revenueChart"></canvas>
                </div>
            </div>
        </div>

        <!-- Biểu đồ sản phẩm bán chạy -->
        <div class="col-md-4">
            <div class="card shadow animate__animated animate__fadeInRight">
                <div class="card-header bg-info text-white">
                    <strong>🔥 Top sản phẩm bán chạy</strong>
                </div>
                <div class="card-body">
                    <canvas id="topProductChart"></canvas>
                </div>
            </div>
        </div>
    </div>

    <!-- Bảng sản phẩm bán chạy -->
    @*<div class="card shadow animate__animated animate__fadeInUp">
        <div class="card-header bg-dark text-white">
            <strong>📌 Danh sách sản phẩm bán chạy nhất</strong>
        </div>
        <div class="card-body table-responsive">
            <table class="table table-striped table-hover">
                <thead class="thead-dark">
                    <tr>
                        <th>Sản phẩm</th>
