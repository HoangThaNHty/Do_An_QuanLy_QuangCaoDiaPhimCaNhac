                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>*@

</div>


<!-- ====== CHART SCRIPT ====== -->
<script>
    // Revenue by month
    var labelsRevenue = [];
    var dataRevenue = [];

    @foreach (var r in ViewBag.RevenueByMonth)
    {
        @:labelsRevenue.push("@r.Month");
        @:dataRevenue.push(@r.Revenue);
    }

    var ctx = document.getElementById('revenueChart').getContext('2d');
    new Chart(ctx, {
        type: 'bar',
        data: {
            labels: labelsRevenue,
            datasets: [{
                label: 'Doanh thu (VNĐ)',
                data: dataRevenue,
                backgroundColor: 'rgba(54, 162, 235, 0.6)',
                borderColor: 'rgba(54, 162, 235, 1)',
                borderWidth: 2
            }]
        },
        options: {
            responsive: true,
            animation: { duration: 1200 },
            scales: {
                y: {
                    beginAtZero: true,
                    ticks: { callback: value => value.toLocaleString() }
                }
            }
        }
    });

    // Top products pie chart
    var productNames = [];
    var productSold = [];

    @foreach (var p in ViewBag.TopProducts)
    {
        @:productNames.push("@p.ProductName");
        @:productSold.push(@p.TotalSold);
    }

    var ctx2 = document.getElementById('topProductChart').getContext('2d');
    new Chart(ctx2, {
        type: 'pie',
        data: {
            labels: productNames,
            datasets: [{
                data: productSold,
                backgroundColor: [
                    '#ff6384', '#36a2eb', '#ffcd56', '#4bc0c0', '#9966ff',
                    '#ff9f40', '#ff6384', '#36a2eb', '#ffcd56', '#4bc0c0'
                ]
            }]
        },
        options: {
            responsive: true,
            animation: { duration: 1300 }
        }
    });
</script>

<style>
    .card {
        border-radius: 12px;
    }

    .table-hover tbody tr:hover {
        background-color: #f1f1f1;
    }
</style>
