@model IEnumerable<DoAnQuanLyQuangCaoDiaPhimCaNhac.Models.DonHang>

@{
    ViewBag.Title = "Quản Lý Đơn Hàng";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<!DOCTYPE html>
<html lang="vi">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>@ViewBag.Title - MusicWeb</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet" />
    <style>
        body {
            background-color: #000;
            color: white;
        }

        .card {
            background-color: #111;
            border: 1px solid white;
            margin-bottom: 20px;
        }

        .table {
            color: white;
        }

            .table thead {
                background-color: #222;
            }

            .table tbody tr:hover {
                background-color: #222;
            }

        .badge {
            font-size: 0.9rem;
        }

        .status-select {
            background-color: #222;
            color: white;
            border: 1px solid #555;
        }

        .btn-outline-light {
            border-color: #007bff;
            color: #007bff;
        }

            .btn-outline-light:hover {
                background-color: #007bff;
                color: white;
            }

        .card-header h5 {
            color: white !important;
            font-weight: bold;
        }


    </style>
</head>
<body>
    <div class="container-fluid mt-4">
        <div class="row">
            <!-- Sidebar -->
            <div class="col-md-2">
                <div class="list-group">
                    <a href="~/Seller" class="list-group-item list-group-item-action" style="background-color: #111; border: 1px solid white; color: white;">📊 Tổng Quan</a>
                    <a href="~/Seller/Products" class="list-group-item list-group-item-action" style="background-color: #111; border: 1px solid white; color: white;">📦 Quản Lý Sản Phẩm</a>
                    <a href="~/Seller/Orders" class="list-group-item list-group-item-action active" style="background-color: #007bff; border-color: #007bff;">📋 Quản Lý Đơn Hàng</a>
                    <a href="~/Seller/Revenue" class="list-group-item list-group-item-action" style="background-color: #111; border: 1px solid white; color: white;">💰 Thống Kê Doanh Thu</a>
                    <a href="~/Category"
                       class="list-group-item list-group-item-action"
                       style="background-color:#111; border:1px solid white; color:white;">
                        🎵 Quản Lý Thể Loại
                    </a>
                </div>
            </div>

            <!-- Main Content -->
            <div class="col-md-10">
                <h2 class="mb-4">📦 QUẢN LÝ ĐƠN HÀNG</h2>

                @if (TempData["ErrorMessage"] != null)
                {
                    <div class="alert alert-danger">@TempData["ErrorMessage"]</div>
                }
                @if (TempData["SuccessMessage"] != null)
                {
                    <div class="alert alert-success">@TempData["SuccessMessage"]</div>
                }

                <div class="card">
                    <div class="card-header">
                        <h5>Danh Sách Đơn Hàng</h5>
                    </div>
                    <div class="card-body table-responsive">
                        <table class="table table-bordered align-middle">
                            <thead>
                                <tr>
                                    <th>Mã Đơn</th>
                                    <th>Khách Hàng</th>
                                    <th>Ngày Đặt</th>
                                    <th>Ngày Giao</th>
                                    <th>Tổng Tiền</th>
                                    <th>Thanh Toán</th>
                                    <th>Trạng Thái</th>
                                    <th>Cập Nhật</th>
                                    <th>Chi Tiết</th>
                                </tr>
                            </thead>
                            <tbody>
                                @foreach (var order in Model)
                                {
                                    string statusBadge = "";
                                    switch (order.TinhTrangGiaoHang)
                                    {
                                        case 0:
                                            statusBadge = "badge bg-warning text-dark";
                                            break;
                                        case 1:
                                            statusBadge = "badge bg-info text-dark";
                                            break;
                                        case 2:
                                            statusBadge = "badge bg-success";
                                            break;
                                        default:
                                            statusBadge = "badge bg-secondary";
                                            break;
                                    }


                                    <tr>
                                        <td>@order.MaDonHang</td>
                                        <td>@order.KhachHang.HoTen</td>
                                        <td>@order.NgayDat.ToString("dd/MM/yyyy HH:mm")</td>
                                        <td>@(order.NgayGiao.HasValue ? order.NgayGiao.Value.ToString("dd/MM/yyyy HH:mm") : "Chưa giao")</td>
                                        <td>@order.TongTien.ToString("N0") ₫</td>
                                        <td>
                                            @(order.DaThanhToan ?
                                                Html.Raw("<span class='badge bg-success'>Đã Thanh Toán</span>") :
                                                Html.Raw("<span class='badge bg-danger'>Chưa Thanh Toán</span>"))
                                        </td>
                                        <td>
                                            <span class="@statusBadge">
                                                @(order.TrangThaiGiaoHang != null ? order.TrangThaiGiaoHang.TenTrangThai : "Không xác định")
                                            </span>

                                        </td>
                                        <td>
                                            <select class="form-select form-select-sm status-select" data-id="@order.MaDonHang">
                                                @foreach (var s in ViewBag.TrangThaiList as SelectList)
                                                {
                                                    <option value="@s.Value" @(s.Value == order.TinhTrangGiaoHang.ToString() ? "selected" : "")>@s.Text</option>
                                                }
                                            </select>
                                        </td>
                                        <td>
                                            <a href="~/Seller/OrderDetails/@order.MaDonHang" class="btn btn-sm btn-outline-light">Xem</a>
                                        </td>
                                    </tr>
                                }
                            </tbody>
                        </table>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <!-- Script -->
    <script src="https://code.jquery.com/jquery-3.6.0.min.js"></script>
    <script>
        $(".status-select").change(function () {
            var orderId = $(this).data("id");
            var status = $(this).val();

            $.ajax({
                url: '@Url.Action("UpdateOrderStatus", "Seller")',
                type: 'POST',
                data: { orderId: orderId, status: status },
                success: function (res) {
                    if (res.success) {
                        alert(res.message);
                        location.reload();
                    } else {
                        alert(res.message);
                    }
                },
                error: function () {
                    alert("Có lỗi xảy ra khi cập nhật trạng thái!");
                }
            });
        });
    </script>
</body>
</html>
